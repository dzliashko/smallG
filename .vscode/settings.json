{
	"editor.defaultFormatter": "biomejs.biome",
	"editor.formatOnSave": true,

	"editor.codeActionsOnSave": {
		"source.organizeImports": "explicit",
		"source.fixAll": true
	},
	"biome.enabled": true,
	"biome.lint": true,
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	}
}
